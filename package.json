{
  "name": "fractured-earth",
  "version": "0.1.0",
  "description": "Mobile-first game platform - shared codebase for web and Android",
  "private": true,
  "scripts": {
    "dev": "cd src && npm run dev",
    "build": "cd src && npm run build",
    "build:static": "cd src && npm run build",
    "start": "cd src && npm run start",
    "lint": "cd src && npm run lint",
    "type-check": "cd src && tsc --noEmit",
    "android:build": "npm run build && echo 'Android can now call API endpoints at /api/*'",
    "android:artifacts": "powershell -ExecutionPolicy Bypass -File ./scripts/web/build-and-deploy.ps1 -Force",
    "android:artifacts:push": "powershell -ExecutionPolicy Bypass -File ./scripts/web/build-and-deploy.ps1 -Push -Force",
    "android:artifacts:no-push": "powershell -ExecutionPolicy Bypass -File ./scripts/web/build-and-deploy.ps1 -SkipGit -Force",
    "android": "echo 'Build the web app with: npm run build'",
    "clean": "cd src && npm run clean"
  },
  "keywords": [
    "fractured-earth",
    "game",
    "mobile-first",
    "web",
    "android"
  ],
  "author": "Carter",
  "license": "MIT",
  "dependencies": {
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18"
  }
}
