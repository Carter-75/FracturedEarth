# Copy to local.properties and fill values
sdk.dir=C:/Users/you/AppData/Local/Android/Sdk

# AdMob test IDs for debug/local testing
ADMOB_APP_ID=ca-app-pub-3940256099942544~3347511713
ADMOB_BANNER_AD_UNIT=ca-app-pub-3940256099942544/6300978111
ADMOB_INTERSTITIAL_AD_UNIT=ca-app-pub-3940256099942544/1033173712

# AdMob production IDs for release builds
ADMOB_APP_ID_RELEASE=
ADMOB_BANNER_AD_UNIT_RELEASE=
ADMOB_INTERSTITIAL_AD_UNIT_RELEASE=

REVENUECAT_PUBLIC_KEY=
REVENUECAT_ADFREE_ENTITLEMENT=ad_free

# Vercel KV — from Vercel Dashboard > Storage > KV > .env.local
VERCEL_KV_REST_URL=
VERCEL_KV_REST_TOKEN=

# Google Sign-In — Web Client ID from console.cloud.google.com (NOT the Android client ID)
GOOGLE_WEB_CLIENT_ID=

# Local Wi-Fi room host URL (device running the web app on your LAN)
# Example: http://192.168.1.42:3000
LAN_ROOM_SERVER_URL=
