# Redis — standard Redis connection URL (redis://user:pass@host:port)
# Set REDIS_URL in your Vercel project → Settings → Environment Variables
REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_HOST:PORT

# Google OAuth — create credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
