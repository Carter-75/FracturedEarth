# Copy to keystore.properties (do not commit real secrets)
# Used by android-app/build.gradle.kts for release signing

# Absolute path or repo-relative path to upload keystore/jks
storeFile=C:/secure/path/to/your-upload-key.jks

# Keystore password
storePassword=

# Key alias inside keystore
keyAlias=upload

# Key password
keyPassword=
